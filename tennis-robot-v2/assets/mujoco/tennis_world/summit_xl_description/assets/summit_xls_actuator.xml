<mujocoinclude>

    <actuator>
        <!-- 
        改用 velocity 执行器以精确控制速度
        
        计算依据（第2次优化）：
        - 实测最大速度: vx_max=5.0 m/s, vy_max=2.0 m/s, wz_max=4.0 rad/s
        - 轮子半径: r=0.11 m
        - 前进所需轮速: ω = 5.0/0.11 ≈ 45.45 rad/s
        - 侧向所需轮速: ω = 2.0/0.11 ≈ 18.18 rad/s
        - 旋转所需轮速: ω = (L+W)*wz/r ≈ 0.8*4.0/0.11 ≈ 29 rad/s
        - 组合运动最大值: √(45²+18²+29²) ≈ 58 rad/s
        - 留2倍余量以补偿摩擦和动力学损失: 58 * 2 ≈ 116 rad/s
        - 设置 ctrlrange=[-120, 120] rad/s
        
        kv=5: 降低速度增益以提升稳定性（避免震荡）
        -->
        <velocity name="front_right_wheel_rolling_joint" joint="front_right_wheel_rolling_joint" ctrlrange="-120 120" kv="5"/>
        <velocity name="front_left_wheel_rolling_joint"  joint="front_left_wheel_rolling_joint"  ctrlrange="-120 120" kv="5"/>
        <velocity name="back_right_wheel_rolling_joint"  joint="back_right_wheel_rolling_joint"  ctrlrange="-120 120" kv="5"/>
        <velocity name="back_left_wheel_rolling_joint"   joint="back_left_wheel_rolling_joint"   ctrlrange="-120 120" kv="5"/>
    </actuator>

</mujocoinclude>